{
  "name": "remote-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native webpack-start --port 9001",
    "ios": "react-native run-ios",
    "android": "react-native run-android",
    "bundle:ios": "react-native webpack-bundle --platform ios --dev false --entry-file index.js",
    "bundle:android": "react-native webpack-bundle --platform android --dev false --entry-file index.js",
    "bundle:android:obf": "yarn bundle:android && node ./obfuscate-bundles.mjs ./build/android",
    "bundle:ios:obf": "yarn bundle:ios && node ./obfuscate-bundles.mjs ./build/ios"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.84.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@callstack/repack": "^5.0.0",
    "@react-native-community/cli": "^15.0.0",
    "@react-native-community/cli-platform-android": "^15.0.0",
    "@react-native-community/cli-platform-ios": "^15.0.0",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@types/react": "^19.0.0",
    "babel-loader": "^9.1.3",
    "javascript-obfuscator": "^5.4.1",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.6.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-obfuscator": "^3.6.1"
  },
  "engines": {
    "node": ">=18"
  }
}
