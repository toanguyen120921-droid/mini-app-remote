{
  "name": "movies-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "react-native webpack-start --port 9004",
    "ios": "react-native run-ios --port 9004",
    "android": "react-native run-android --port 9004",
    "postinstall": "patch-package",
    "bundle:ios": "react-native webpack-bundle --platform ios --dev false --entry-file index.js && node ./embed-federation-exposes.mjs ./build/ios",
    "bundle:android": "react-native webpack-bundle --platform android --dev false --entry-file index.js && node ./embed-federation-exposes.mjs ./build/android",
    "bundle:android:obf": "yarn bundle:android && node ./obfuscate-bundles.mjs ./build/android",
    "bundle:ios:obf": "yarn bundle:ios && node ./obfuscate-bundles.mjs ./build/ios",
    "package:cdn": "./scripts/package-for-cdn.sh",
    "package:cdn:version": "./scripts/package-for-cdn.sh"
  },
  "dependencies": {
    "install": "^0.13.0",
    "npm": "^11.12.1",
    "react": "19.2.3",
    "react-native": "0.85.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@callstack/repack": "^5.0.0",
    "@module-federation/enhanced": "^0.15.0",
    "@nkzw/create-context-hook": "^1.1.0",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/metro-config": "0.85.0",
    "@react-navigation/bottom-tabs": "7.15.9",
    "@react-navigation/compat": "5.3.20",
    "@react-navigation/material-top-tabs": "7.4.23",
    "@react-navigation/native": "7.2.2",
    "@react-navigation/native-stack": "7.14.11",
    "@react-navigation/stack": "7.8.10",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.99.0",
    "@types/react": "^19.0.0",
    "@ungap/structured-clone": "^1.3.0",
    "add": "^2.0.6",
    "axios": "^1.7.9",
    "babel-loader": "^9.1.3",
    "javascript-obfuscator": "^5.4.1",
    "patch-package": "^8.0.1",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-image-picker": "^8.2.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-pager-view": "8.0.1",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.4",
    "react-native-tab-view": "4.3.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-video": "^7.0.0-beta.9",
    "react-native-worklets": "^0.8.1",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.8.3",
    "webpack": "5.89.0",
    "webpack-cli": "5.1.4",
    "webpack-obfuscator": "^3.6.1",
    "yarn": "^1.22.22",
    "zustand": "^5.0.12"
  },
  "engines": {
    "node": ">=18"
  }
}
